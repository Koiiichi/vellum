# Gmail + Google Cloud
GMAIL_ADDRESS=vellum-agent@gmail.com
GMAIL_CREDENTIALS_PATH=credentials.json
GMAIL_TOKEN_PATH=token.json
PUBSUB_TOPIC=projects/<project-id>/topics/vellum-gmail-push
PUBSUB_SUBSCRIPTION=projects/<project-id>/subscriptions/vellum-gmail-sub

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5.4-mini

# Agent config
MAX_CONCURRENT_WORKERS=2
MAX_DOCUMENTS=10
DOWNLOAD_TIMEOUT_MS=30000
SCRAPER_RETRY_ATTEMPTS=3
SCRAPER_RETRY_BACKOFF_S=2

# Parser rate limiting
PARSER_MAX_CALLS_PER_MINUTE=20

# Scraper
UARB_BASE_URL=https://uarb.novascotia.ca/fmi/webd/UARB15
SELECTOR_TIMEOUT_MS=15000
SCRAPER_HEADLESS=true

# Outbound branded replies
EMAIL_FROM=vellum-agent@gmail.com
EMAIL_FROM_NAME=Vellum

# Large-archive delivery (archives over the limit are uploaded here and linked)
GCS_BUCKET=
MAX_ATTACHMENT_MB=24
DELIVERY_RETENTION_DAYS=7
EMAIL_LOGO_URL=

# Server
HOST=0.0.0.0
PORT=8000
